# Project Tracker API v2 Configuration

# Server
PORT=9546
WEBUI_PORT=8081
BIND_ADDRESS=0.0.0.0

# Trusted Proxies (for X-Forwarded-For parsing behind nginx)
TRUSTED_PROXIES=127.0.0.1,172.17.0.1

# Rate Limiting
RATE_LIMIT_ENABLED=true
READ_RPM=120
WRITE_RPM=30
BURST_SIZE=15
BAN_THRESHOLD=10
BAN_DURATION=600

# Request Limits
MAX_BODY_SIZE=10485760
MAX_SLUG_LENGTH=64
MAX_FILENAME_LENGTH=128

# CORS
CORS_ORIGINS=http://192.168.1.239:8081,http://localhost:8081

# Logging
LOG_LEVEL=INFO

# Security
ENABLE_SECURITY_HEADERS=true
SESSION_TIMEOUT=86400
SESSION_MAX=50
BIND_SESSION_TO_IP=true

# Allowed File Extensions
ALLOWED_EXTENSIONS=.md,.json,.txt,.yaml,.yml,.toml,.cfg,.ini,.sh,.py,.cpp,.h,.rs,.js,.css,.html
